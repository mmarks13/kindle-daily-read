# Copy to .env and fill in. .env is gitignored — never commit real values.
# This publication uses the logged-in Claude Pro CLI for the writing step; do NOT
# set ANTHROPIC_API_KEY here (that switches to paid API billing).

# Author/publisher name written into EPUB metadata and the Kindle library title.
AUTHOR_NAME="Semi-Supervised"

# --- Kindle delivery ---------------------------------------------------------
# The issue EPUB is emailed to your Kindle via Amazon Send-to-Kindle.
# SENDER_EMAIL:       the Gmail address you send from. It MUST be on your Amazon
#                     Approved Personal Document E-mail List for delivery to work.
# KINDLE_EMAIL:       your @kindle.com address (Amazon > Devices > your Kindle).
# GMAIL_APP_PASSWORD: a Google App Password for SENDER_EMAIL (not your login password).
SENDER_EMAIL="you@gmail.com"
KINDLE_EMAIL="you_xxxxxx@kindle.com"
GMAIL_APP_PASSWORD="xxxxxxxxxxxxxxxx"
